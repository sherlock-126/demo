# Production Environment Configuration
# Copy this file to .env for production deployment

# === DOMAIN CONFIGURATION ===
DOMAIN=demo.yourdomain.com
SSL_EMAIL=admin@yourdomain.com

# === REQUIRED SECRETS (CHANGE ALL OF THESE) ===

# OpenAI API Configuration
OPENAI_API_KEY=sk-prod-your-api-key-here

# Security Secrets (Generate with: openssl rand -base64 32)
JWT_SECRET=change-this-to-random-64-char-string-in-production
ADMIN_PASSWORD=change-this-strong-password

# === LLM PROVIDER SETTINGS ===

# Provider Selection
LLM_PROVIDER=openai_api
OPENAI_MODEL=gpt-4-turbo-preview
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# === SERVICE CONFIGURATION ===

# Database
DATABASE_URL=sqlite:///./data/app.db

# CORS Configuration (Update with your domains)
CORS_ORIGINS=https://demo.yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=https://demo.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://demo.yourdomain.com/ws
NODE_ENV=production

# === RESOURCE LIMITS ===

# Container Resource Limits (Optimized for Windows Hyper-V)
DEPLOY_RESOURCES_LIMITS_CPUS=0.5
DEPLOY_RESOURCES_LIMITS_MEMORY=2G

# === MONITORING ===

# Grafana Admin Credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-this-grafana-password

# Alert Webhook (Optional - for Slack/Discord/etc)
ALERT_WEBHOOK=

# === LOGGING ===

LOG_LEVEL=WARNING
LOG_FILE=/app/logs/production.log

# === NGINX CONFIGURATION ===

# Rate Limiting
RATE_LIMIT_GENERAL=10r/s
RATE_LIMIT_API=30r/s
RATE_LIMIT_AUTH=5r/m

# Client Settings
CLIENT_MAX_BODY_SIZE=200M
CLIENT_BODY_TIMEOUT=60s
CLIENT_HEADER_TIMEOUT=60s

# === SECURITY SETTINGS ===

# ModSecurity WAF
MODSECURITY_MODE=DetectionOnly  # Change to 'On' after testing

# SSL/TLS
SSL_PROTOCOLS="TLSv1.2 TLSv1.3"
SSL_CIPHERS="ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES128-GCM-SHA256"

# Security Headers
HSTS_MAX_AGE=31536000
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"

# === BACKUP SETTINGS ===

BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily

# === VERSION CONTROL ===

# Container image version tag
VERSION=latest

# === FEATURE FLAGS ===

ENABLE_MONITORING=true
ENABLE_WAF=true
ENABLE_RATE_LIMITING=true
ENABLE_CACHE=true

# === EXTERNAL SERVICES (Optional) ===

# CloudFlare (if using)
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# Sentry Error Tracking (if using)
SENTRY_DSN=

# === STREAMLIT SPECIFIC ===

STREAMLIT_SERVER_MAX_UPLOAD_SIZE=200
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false