# Docker Environment Configuration
# Copy this file to .env.docker and update with your values

# ====================
# OpenAI Configuration
# ====================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# ====================
# LLM Provider Settings
# ====================
# Options: openai_api (default), cli_chatgpt, revchatgpt
LLM_PROVIDER=openai_api

# For CLI-based providers (optional)
CHATGPT_CLI_COMMAND=/usr/local/bin/chatgpt-cli
CHATGPT_AUTH_TOKEN=
REVCHATGPT_ACCESS_TOKEN=
REVCHATGPT_SESSION_TOKEN=

# ====================
# Application Settings
# ====================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Language settings
DEFAULT_LANGUAGE=vi

# Number of slides for content generation
DEFAULT_SLIDES=5

# ====================
# Resource Limits
# ====================
# These are set in docker-compose.yml but can be overridden
DOCKER_MEMORY_LIMIT=4G
DOCKER_CPU_LIMIT=2.0

# ====================
# Paths (usually not changed)
# ====================
DATA_PATH=/app/data
OUTPUT_PATH=/app/output
VIDEOS_PATH=/app/videos
AUDIO_PATH=/app/audio
ASSETS_PATH=/app/assets
AUTH_PATH=/app/.auth
LOGS_PATH=/app/logs

# ====================
# Network Settings
# ====================
# Port for potential web interface
APP_PORT=8000

# Timezone
TZ=Asia/Ho_Chi_Minh

# ====================
# Debug Settings
# ====================
PYTHONUNBUFFERED=1
DEBUG_MODE=false