# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Model Configuration
OPENAI_MODEL=gpt-4-turbo-preview
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=data/logs/generation.log

# Optional: Storage
DATA_DIR=data
CACHE_ENABLED=false

# Docker-Specific Configuration
# Copy to .env.docker for Docker deployment
# See .env.docker.example for full Docker configuration

# LLM Provider Selection (for future CLI-based providers)
# Options: openai_api (default), cli_chatgpt, revchatgpt
LLM_PROVIDER=openai_api

# CLI Provider Settings (optional, for future use)
CHATGPT_CLI_COMMAND=/usr/local/bin/chatgpt-cli
CHATGPT_AUTH_TOKEN=
REVCHATGPT_ACCESS_TOKEN=