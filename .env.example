# LLM Provider Configuration
# Options: openai_api, cli_chatgpt, revchatgpt, mock
LLM_PROVIDER=openai_api

# OpenAI API Configuration (for openai_api provider)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# CLI Provider Configuration (for cli_chatgpt provider)
CHATGPT_CLI_COMMAND=chatgpt-cli
CLI_TIMEOUT=60

# RevChatGPT Configuration (for revchatgpt provider)
REVCHATGPT_ACCESS_TOKEN=
REVCHATGPT_SESSION_TOKEN=
REVCHATGPT_TIMEOUT=90

# General Configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=data/logs/generation.log

# Optional: Storage
DATA_DIR=data
CACHE_ENABLED=false