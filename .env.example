# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Model Configuration
OPENAI_MODEL=gpt-4-turbo-preview
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# LLM Provider Configuration
LLM_PROVIDER=openai_api
# Alternative: chatgpt_cli, local_llm
CHATGPT_CLI_COMMAND=/usr/local/bin/chatgpt-cli

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=data/logs/generation.log

# Storage Configuration
DATA_DIR=data
CACHE_ENABLED=false

# Backend Configuration
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3001,http://localhost:8501

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NODE_ENV=development

# Production Configuration (optional)
DOMAIN=demo.yourdomain.com
SSL_EMAIL=admin@yourdomain.com
VERSION=latest
MODSECURITY_MODE=DetectionOnly

# Docker Resource Limits (optional override)
# CPU_LIMIT=0.5
# MEMORY_LIMIT=2G